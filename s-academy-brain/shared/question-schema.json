{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "S.Academy Question Bank Schema",
  "type": "object",
  "required": ["course_id", "version", "questions"],
  "properties": {
    "course_id": {"type": "string"},
    "version": {"type": "string"},
    "status": {"enum": ["draft", "in-review", "approved", "published", "archived"]},
    "questions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "question", "answer", "type", "chapter"],
        "properties": {
          "id": {"type": "string"},
          "sl_no": {"type": ["integer", "null"]},
          "question": {"type": "string"},
          "answer": {"type": "string"},
          "type": {"type": "string"},
          "chapter": {"type": ["integer", "string"]},
          "subchapter": {"type": ["string", "null"]},
          "difficulty": {"type": "string"},
          "evaluation_criteria": {"type": "array", "items": {"type": "string"}}
        }
      }
    }
  }
}
